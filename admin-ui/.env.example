# Pulsys admin API (pulsys admin listener when PULSYS_DB_DSN is set)
PULSYS_ADMIN_API=http://127.0.0.1:6060

# Proxy ingress URL embedded in Models page download examples (optional override)
# NEXT_PUBLIC_PROXY_BASE_URL=http://127.0.0.1:8080

# HF ingress port when derived from the console URL (3000→8082 docker, 3001→8080 dev)
# NEXT_PUBLIC_PROXY_PORT=8080
