---
import globalStyles from '../styles/global.css?inline';
import {
  brandName,
  companyLegalName,
  contactHref,
  docsHref,
  repoHref,
  plausibleDomain,
  plausibleScriptSrc,
} from '../site.config';

interface Props {
  title: string;
  description?: string;
  current?: 'home' | 'blog' | 'privacy';
  /** Marketing home: force dark palette (Linear / Vercel / Stripe pattern). */
  marketing?: boolean;
  ogType?: 'website' | 'article';
  publishedTime?: string;
}

const {
  title,
  description = 'Fast, reliable model and dataset downloads, cached for your team.',
  current,
  marketing = false,
  ogType = 'website',
  publishedTime,
} = Astro.props;
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
const ogImage = Astro.site ? new URL(`${base}og.png`, Astro.site).href : `${base}og.png`;
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.href;
const plausibleOrigin = plausibleDomain ? new URL(plausibleScriptSrc).origin : '';
const contentSecurityPolicy = [
  "default-src 'self'",
  "base-uri 'self'",
  "object-src 'none'",
  `script-src 'self' 'wasm-unsafe-eval'${plausibleOrigin ? ` ${plausibleOrigin}` : ''}`,
  "style-src 'self' 'unsafe-inline'",
  "img-src 'self' data:",
  "font-src 'self'",
  `connect-src 'self'${plausibleOrigin ? ` ${plausibleOrigin}` : ''}`,
  "form-action 'self'",
  'upgrade-insecure-requests',
].join('; ');
---

<!doctype html>
<html lang="en" class:list={[{ 'theme-dark': marketing }]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050507" />
    <meta http-equiv="Content-Security-Policy" content={contentSecurityPolicy} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="icon" href={`${base}favicon-32.png`} type="image/png" sizes="32x32" />
    <link rel="icon" href={`${base}favicon-16.png`} type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    {ogType === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <style is:inline set:html={globalStyles}></style>
    {
      plausibleDomain && (
        <script
          defer
          data-domain={plausibleDomain}
          src={plausibleScriptSrc}
        />
      )
    }
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class:list={['header', { 'header--marketing': marketing }]}>
      <nav class="nav-inner" aria-label="Primary">
        <a class:list={['brand', { 'brand-mark': marketing }]} href="/" aria-label={`${brandName} home`}>
          <svg
            class="brand__logo"
            viewBox="0 0 32 32"
            width="22"
            height="22"
            aria-hidden="true"
          >
            <path
              d="M3 16 H10 L13.5 7 L18.5 25 L22 16 H29"
              fill="none"
              stroke="currentColor"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
          {brandName}
        </a>
        {
          marketing ? (
            <div class="nav-actions">
              <a class="nav-text" href={docsHref}>Docs</a>
              <a class="nav-text" href="/blog" aria-current={current === 'blog' ? 'page' : undefined}>
                Blog
              </a>
              <a
                class="btn btn--secondary btn--nav gh-stars"
                href={repoHref}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Star pulsys on GitHub"
              >
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/></svg>
                <span>Star</span>
              </a>
            </div>
          ) : (
            <ul class="nav-links">
              <li>
                <a href="/" aria-current={current === 'home' ? 'page' : undefined}>
                  Overview
                </a>
              </li>
              <li>
                <a href="/blog" aria-current={current === 'blog' ? 'page' : undefined}>
                  Blog
                </a>
              </li>
            </ul>
          )
        }
      </nav>
    </header>
    <main id="main" class:list={[{ 'main--marketing': marketing }]}>
      <slot />
    </main>
    <footer class="footer">
      <div class="footer-inner">
        <p>
          © {year} {companyLegalName} · Apache-2.0 ·
          <a href={repoHref} target="_blank" rel="noopener noreferrer">GitHub</a> ·
          <a href={docsHref}>Docs</a> ·
          <a href={contactHref} target="_blank" rel="noopener noreferrer">Discussions</a> ·
          <a href="/privacy">Privacy</a>
        </p>
      </div>
    </footer>
  </body>
</html>
