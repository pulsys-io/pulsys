---
import Layout from '../../layouts/Layout.astro';
import { brandName } from '../../site.config';
import { posts } from '../../data/posts';

const monthYear = (iso: string) =>
  new Date(`${iso}T00:00:00Z`).toLocaleDateString('en-US', {
    month: 'long',
    year: 'numeric',
    timeZone: 'UTC',
  });
---

<Layout
  title={`Blog · ${brandName}`}
  description={`Performance work and internals from building ${brandName}.`}
  current="blog"
  marketing
>
  <div class="lp blog-index">
    <section class="blog-index__hero">
      <h1 class="lp-title">Blog</h1>

      <section class="post-list" aria-label="Published posts">
        {posts.map((post) => (
          <article class="post-card blog-post-card">
            <p class="post-meta tabular">{monthYear(post.published)}</p>
            <h2 class="post-title">
              <a href={`/blog/${post.slug}/`}>{post.title}</a>
            </h2>
            <p class="muted">{post.description}</p>
          </article>
        ))}
      </section>
    </section>
  </div>
</Layout>
