---
import Layout from '../layouts/Layout.astro';
import ArchDiagram from '../components/ArchDiagram.astro';
import { repoHref, docsHref, getStartedHref, brandName, marketing } from '../site.config';
import { headline } from '../generated/headline';
import 'asciinema-player/dist/bundle/asciinema-player.css';

const { cliBinName, demoModelId } = marketing;
const base = import.meta.env.BASE_URL;
const rpsLabel =
  headline.peakRpsMillions >= 1
    ? `${headline.peakRpsMillions.toFixed(2).replace(/\.?0+$/, '')}M`
    : `${Math.round(headline.peakRps / 1000)}k`;
const gbLabel = `${Math.round(headline.peakGbPerS)} GB/s`;
---

<Layout
  title={`${brandName} · Hugging Face pull-through cache`}
  description={marketing.pageDescription}
  current="home"
  marketing
>
  <div class="lp">
    <section class="lp-hero">
      <div class="lp-hero__grid">
        <div class="lp-hero__copy">
          <p class="lp-badge">{marketing.categoryBadge}</p>
          <h1 class="lp-title">{marketing.heroTitle}</h1>
          <p class="lp-lead">{marketing.heroLead}</p>
          <div class="lp-cta-row">
            <a class="btn btn--primary btn--lg lp-cta" href={getStartedHref}>{marketing.primaryCta}</a>
            <a
              class="btn btn--secondary btn--lg lp-cta"
              href={repoHref}
              target="_blank"
              rel="noopener noreferrer">{marketing.secondaryCta}</a>
          </div>
        </div>

        <div class="lp-hero__visual" aria-label="Terminal demonstration">
          <div class="lp-terminal">
            <div class="lp-terminal__chrome">
              <span class="lp-terminal__dot"></span>
              <span class="lp-terminal__dot"></span>
              <span class="lp-terminal__dot"></span>
            </div>
            <div id="asciinema-hf-demo" class="asciinema-hero lp-terminal__body"></div>
            <pre
              class="asciinema-static-fallback lp-terminal__fallback"
              tabindex="0"
              aria-label="Static terminal transcript"><code>$ export HF_ENDPOINT=http://localhost:8082
$ export HF_TOKEN=pulsys_...
$ {cliBinName} download {demoModelId}
Resolving data files...
Download complete</code></pre>
          </div>
        </div>
      </div>
    </section>

    <section class="lp-trust" aria-label="Project trust signals">
      <ul class="lp-trust__row">
        {marketing.trustPills.map((pill) => (
          <li class="lp-trust__pill">{pill}</li>
        ))}
      </ul>
    </section>

    <section class="lp-value" aria-labelledby="lp-value-title">
      <h2 id="lp-value-title" class="lp-value__title">{marketing.valueTitle}</h2>
      <p class="lp-value__lead">{marketing.valueLead}</p>
    </section>

    <section class="lp-proof" aria-labelledby="lp-proof-title">
      <h2 id="lp-proof-title" class="lp-section-title lp-section-title--center">{marketing.proofTitle}</h2>

      <ul class="lp-stats">
        <li class="lp-stat">
          <span class="lp-stat__value tabular">{rpsLabel}</span>
          <span class="lp-stat__label">req/s @ 4 KiB (loopback)</span>
        </li>
        <li class="lp-stat">
          <span class="lp-stat__value tabular">{gbLabel}</span>
          <span class="lp-stat__label">throughput @ 16 MiB</span>
        </li>
        <li class="lp-stat">
          <span class="lp-stat__value tabular tabular-sm">{headline.instanceType}</span>
          <span class="lp-stat__label">{headline.vcpu} vCPU · {headline.variant}</span>
        </li>
        <li class="lp-stat">
          <span class="lp-stat__value tabular tabular-sm">io_uring</span>
          <span class="lp-stat__label">Linux warm path</span>
        </li>
      </ul>

      <div class="lp-charts">
        <figure class="lp-chart">
          <img src={`${base}results/ec2/rps.svg`} alt="Request rate by payload (EC2 reference run)" loading="lazy" />
          <figcaption>EC2 saturation · req/s by payload</figcaption>
        </figure>
        <figure class="lp-chart">
          <img src={`${base}results/ec2/throughput.svg`} alt="Throughput by payload (EC2 reference run)" loading="lazy" />
          <figcaption>EC2 saturation · GB/s by payload</figcaption>
        </figure>
      </div>

      <p class="lp-footnote">
        Reference run: {headline.instanceType}, {headline.vcpu} vCPU, kernel {headline.kernel}, variant
        <code>{headline.variant}</code>. Generated {headline.generatedUtc}. Reproduce via the
        <a href={`${docsHref}/benchmarks/`}>benchmarks doc</a>.
      </p>
    </section>

    <section class="lp-features" aria-labelledby="lp-features-title">
      <h2 id="lp-features-title" class="lp-section-title lp-section-title--center">
        {marketing.featuresTitle}
      </h2>
      <ul class="lp-feature-grid" role="list">
        {marketing.features.map((feature) => (
          <li class="lp-feature">
            <h3 class="lp-feature__title">{feature.title}</h3>
            <p class="lp-feature__body">
              {feature.title === 'Warm path at the kernel' ? (
                <>
                  Warm hits use io_uring on Linux 6.1+ and <code>sendfile</code> on macOS. Reference EC2 run (
                  {rpsLabel} req/s, {gbLabel}) and reproduction steps live in the{' '}
                  <a href={`${docsHref}/benchmarks/`}>benchmarks doc</a>.
                </>
              ) : feature.title === 'No client rewrites' ? (
                <>
                  Set <code>HF_ENDPOINT</code> to Pulsys. <code>huggingface_hub</code>, <code>transformers</code>,{' '}
                  <code>datasets</code>, and the <code>hf</code> CLI keep working.
                </>
              ) : feature.title === 'Authenticated by default' ? (
                <>
                  Every request needs a <code>pulsys_*</code> API key from the admin console. Client credentials never
                  reach Hugging Face.
                </>
              ) : (
                feature.body
              )}
            </p>
          </li>
        ))}
      </ul>
    </section>

    <section class="lp-usecases" aria-labelledby="lp-usecases-title">
      <h2 id="lp-usecases-title" class="lp-section-title lp-section-title--center">
        {marketing.usecasesTitle}
      </h2>
      <ul class="lp-usecase-grid" role="list">
        {marketing.usecases.map((usecase) => (
          <li class="lp-usecase">
            <h3 class="lp-usecase__title">{usecase.title}</h3>
            <p class="lp-usecase__body">
              {usecase.title === 'CI fleets' ? (
                <>
                  The same model on every job should not re-cross the public internet. Point <code>HF_ENDPOINT</code> at
                  Pulsys and the second pull is local.
                </>
              ) : (
                usecase.body
              )}
            </p>
          </li>
        ))}
      </ul>
    </section>

    <section class="lp-arch" aria-labelledby="lp-arch-title">
      <h2 id="lp-arch-title" class="lp-section-title lp-section-title--center">
        {marketing.archTitle}
      </h2>
      <ArchDiagram />
    </section>

    <section class="lp-quickstart" aria-labelledby="lp-quickstart-title">
      <h2 id="lp-quickstart-title" class="lp-section-title lp-section-title--center">
        {marketing.finalCtaHeadline}
      </h2>
      <div class="lp-quickstart__panel">
        <pre class="lp-quickstart__code" tabindex="0"><code>export PULSYS_HF_TOKEN=hf_your_readonly_token
docker compose up --build</code></pre>
        <pre class="lp-quickstart__code" tabindex="0"><code>export HF_ENDPOINT=http://localhost:8082
export HF_TOKEN=pulsys_...
{cliBinName} download {demoModelId}</code></pre>
      </div>
      <div class="lp-cta-row lp-cta-row--center">
        <a class="btn btn--primary btn--lg lp-cta" href={getStartedHref}>{marketing.finalPrimaryCta}</a>
        <a
          class="btn btn--secondary btn--lg lp-cta"
          href={repoHref}
          target="_blank"
          rel="noopener noreferrer">{marketing.finalSecondaryCta}</a>
      </div>
    </section>

    <section class="lp-faq" aria-labelledby="lp-faq-title">
      <h2 id="lp-faq-title" class="lp-section-title lp-section-title--center">{marketing.faqTitle}</h2>
      <div class="lp-faq__list" role="list">
        {marketing.faq.map((item) => (
          <details class="lp-faq__item" role="listitem">
            <summary class="lp-faq__q">
              <span class="lp-faq__q-text">{item.q}</span>
              <svg class="lp-faq__chevron" viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
                <path
                  d="M4 6 L8 10 L12 6"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </summary>
            <div class="lp-faq__a">
              <p>
                {item.q === 'Where do credentials live?' ? (
                  <>
                    Pulsys holds a read-only Hugging Face token (<code>PULSYS_HF_TOKEN</code>) for cache misses. Clients
                    use Pulsys API keys from the admin UI. See the{' '}
                    <a href={`${docsHref}/security/`}>security doc</a>.
                  </>
                ) : item.q === 'Which clients work?' ? (
                  <>
                    Any client that speaks the Hugging Face Hub wire protocol. Set <code>HF_ENDPOINT</code> to Pulsys
                    and use a <code>pulsys_*</code> API key as <code>HF_TOKEN</code>.
                  </>
                ) : (
                  item.a
                )}
              </p>
            </div>
          </details>
        ))}
      </div>
    </section>
  </div>

  <script>
    import { create } from 'asciinema-player';

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function mountTerminal() {
      const el = document.getElementById('asciinema-hf-demo');
      if (!el || reduceMotion) return;
      create(`${import.meta.env.BASE_URL}demos/hf-warm-demo.cast`, el, {
        fit: 'width',
        rows: 8,
        cols: 52,
        theme: 'dracula',
        loop: true,
        autoPlay: true,
        speed: 1.0,
      });
    }

    mountTerminal();
  </script>
</Layout>

<style>
  .lp-value {
    padding: clamp(2rem, 4vh, 2.75rem) 0 0;
    text-align: center;
    max-width: 42rem;
    margin: 0 auto;
  }

  .lp-value__title {
    margin: 0;
    font-size: clamp(1.25rem, 2.6vw, 1.75rem);
    font-weight: 650;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }

  .lp-value__lead {
    margin: 0.75rem 0 0;
    font-size: 1rem;
    line-height: 1.55;
    color: var(--text-secondary);
  }

  .lp-charts {
    display: grid;
    gap: 1.25rem;
    margin: 2rem 0 1rem;
  }
  .lp-chart {
    margin: 0;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.02);
  }
  .lp-chart img {
    display: block;
    width: 100%;
    height: auto;
  }
  .lp-chart figcaption {
    padding: 0.65rem 1rem;
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.55);
  }
  @media (min-width: 900px) {
    .lp-charts {
      grid-template-columns: 1fr 1fr;
    }
  }
  .tabular-sm {
    font-size: clamp(1.25rem, 3vw, 1.75rem);
  }

  .lp-features,
  .lp-usecases,
  .lp-quickstart {
    padding: clamp(2.5rem, 5vh, 3.5rem) 0 0;
    border-top: 1px solid var(--separator);
    margin-top: clamp(2.5rem, 5vh, 3.5rem);
  }

  .lp-feature-grid,
  .lp-usecase-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 700px) {
    .lp-feature-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .lp-usecase-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (min-width: 1000px) {
    .lp-feature-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .lp-feature,
  .lp-usecase {
    border: 1px solid var(--separator);
    border-radius: 12px;
    padding: 1.25rem 1.25rem 1.35rem;
    background: color-mix(in srgb, var(--bg-elevated) 70%, transparent);
  }

  .lp-feature__title,
  .lp-usecase__title {
    margin: 0;
    font-size: 0.9875rem;
    font-weight: 650;
    letter-spacing: -0.01em;
  }

  .lp-feature__body,
  .lp-usecase__body {
    margin: 0.5rem 0 0;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--text-secondary);
  }

  .lp-quickstart__panel {
    display: grid;
    gap: 1rem;
    max-width: 46rem;
    margin: 0 auto;
  }

  .lp-quickstart__code {
    margin: 0;
    padding: 1rem 1.25rem;
    border: 1px solid var(--separator);
    border-radius: 12px;
    background: #07080b;
    overflow-x: auto;
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .lp-quickstart__code code {
    background: none;
    border: none;
    padding: 0;
  }

  .lp-cta-row--center {
    justify-content: center;
    margin-top: 2rem;
  }
</style>
